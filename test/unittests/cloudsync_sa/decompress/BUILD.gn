import("//build/test.gni")

module_output_path = "filemanagement/dfs_service"

ohos_unittest("DecompressConfigManagerTest") {
  module_out_path = module_output_path
  
  sources = [
    "decompress_config_manager_test.cpp",
  ]
  
  configs = [
    "//foundation/filemanagement/dfs_service:test_config",
  ]
  
  deps = [
    "//foundation/filemanagement/dfs_service/services/cloudsyncservice:cloudsync_sa",
    "//third_party/googletest:gtest_main",
    "//third_party/json:nlohmann_json_static",
  ]
  
  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
  ]
  
  part_name = "dfs_service"
  subsystem_name = "filemanagement"
}

group("unittest") {
  testonly = true
  deps = [
    ":DecompressConfigManagerTest",
  ]
}